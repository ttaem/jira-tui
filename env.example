# JIRA TUI 환경 변수 설정 예제
# 이 파일을 복사하여 .env 파일로 만들고 값을 설정하세요.
# 그 후 'source .env' 명령어로 환경 변수를 로드할 수 있습니다.

# 필수: JIRA 계정 이메일
export JIRA_EMAIL="your.email@newracom.com"

# 필수: JIRA API 토큰 (https://id.atlassian.com/manage-profile/security/api-tokens 에서 생성)
export JIRA_API_TOKEN="your-api-token-here"

# 선택사항: JIRA 인스턴스 URL (기본값: https://newracom.atlassian.net)
export JIRA_BASE_URL="https://newracom.atlassian.net"

# 이 파일을 사용하는 방법:
# 1. 파일 이름을 .env로 변경: cp env.example .env
# 2. 위의 값들을 실제 값으로 수정
# 3. 환경 변수 로드: source .env
# 4. 프로그램 실행: cargo run 또는 ./run.sh